# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# --- MCP tools (Composio) ---
# Without both of these the server starts with zero tools.
# Get the API key from https://app.composio.dev (Settings -> API Keys).
# The MCP URL is a Tool Router session URL created for one user — see the
# README's Composio setup section.
COMPOSIO_API_KEY=your-composio-api-key
COMPOSIO_MCP_URL=https://backend.composio.dev/tool_router/trs_XXXXXXXX/mcp

# Which Composio user's connections count during briefing source discovery —
# must match the user the COMPOSIO_MCP_URL tool router session was created for.
COMPOSIO_USER_ID=your-composio-user-id

# --- Inference engine ---
# Any OpenAI-compatible endpoint works. Exactly one block should be active.

# Option A — LM Studio (local, private; see docs/README.md for model setup):
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
AGENT_MODEL=openai/gpt-oss-20b

# Option B — Cerebras (cloud, fast; note tool results incl. email bodies
# leave the machine). Key from https://cloud.cerebras.ai:
# LLM_BASE_URL=https://api.cerebras.ai/v1
# LLM_API_KEY=your-cerebras-api-key
# AGENT_MODEL=gpt-oss-120b

# Option C — Ollama (not recommended; 4k context default breaks tool results,
# see docs/ISSUES.md item 7):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# AGENT_MODEL=qwen3:14b

# --- Briefing (optional overrides) ---
# Baseline sources the /briefing fan-out always checks; apps connected in
# Composio are discovered live and appended automatically. BRIEFING_EXCLUDE
# hides connected apps that make bad briefing sources.
# BRIEFING_SOURCES=gmail,github,calendar
# BRIEFING_EXCLUDE=googledocs,googlesheets,googledrive
